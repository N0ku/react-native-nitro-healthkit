{
  "name": "react-native-nitro-healthkit",
  "version": "5.1.0",
  "description": "React Native Nitro module for reading and writing health data — one TypeScript API over Apple HealthKit (iOS) and Android Health Connect.",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "android/build.gradle",
    "android/CMakeLists.txt",
    "android/consumer-rules.pro",
    "android/src/main/AndroidManifest.xml",
    "android/src/main/cpp/**/*.cpp",
    "android/src/main/cpp/**/*.hpp",
    "android/src/main/cpp/**/*.h",
    "android/src/main/kotlin/**/*.kt",
    "cpp",
    "nitro.json",
    "*.podspec",
    "README.md"
  ],
  "scripts": {
    "prepare": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib",
    "build": "tsc",
    "specs": "tsc && nitrogen --logLevel=\"debug\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:android": "cd android && ./gradlew test"
  },
  "keywords": [
    "react-native",
    "nitro",
    "healthkit",
    "health-connect",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N0ku/react-native-nitro-healthkit.git"
  },
  "author": "N0ku",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/N0ku/react-native-nitro-healthkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/N0ku/react-native-nitro-healthkit#readme",
  "dependencies": {
    "react-native-nitro-modules": "^0.30.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "jest": "^29.7.0",
    "nitrogen": "^0.30.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/specs/**"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "verbatimModuleSyntax": false
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|react-native-nitro-modules)/)"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/__mocks__/react-native.js",
      "^react-native-nitro-modules$": "<rootDir>/__mocks__/react-native-nitro-modules.js"
    }
  }
}
